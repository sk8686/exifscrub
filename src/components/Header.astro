---
import { getSupportedLangs, langLabels, formatLangPath } from '../i18n/utils';
import type { Lang } from '../i18n/translations';

interface Props {
  currentPath?: string;
  lang?: string;
  t?: {
    nav: { tool: string; learn: string; switchLang: string };
  };
}

const { currentPath = '/', lang = 'en', t } = Astro.props;
const isToolPage = currentPath === '/' || /^\/[a-z]{2}\/?$/.test(currentPath);
const isLearnPage = !isToolPage && currentPath !== '/404';
const currentLang = lang as Lang;
const supportedLangs = getSupportedLangs();

// Determine the path without the lang prefix for generating alternate language links
function getPathWithoutLang(pathname: string, lang: Lang): string {
  if (lang === 'en') return pathname;
  return pathname.replace(`/${lang}`, '') || '/';
}
const pathWithoutLang = getPathWithoutLang(currentPath, currentLang);
---

<header class="border-b border-[var(--color-border)] bg-white sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href={currentLang === 'en' ? '/' : `/${currentLang}/`} class="flex items-center gap-2 text-lg font-bold text-[var(--color-primary)] no-underline min-h-[44px]">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="w-7 h-7">
        <rect width="32" height="32" rx="6" fill="#2563EB"/>
        <path d="M16 6L8 12v10h16V12L16 6z" fill="none" stroke="white" stroke-width="2"/>
        <circle cx="16" cy="17" r="3" fill="white"/>
      </svg>
      <span>EXIF Scrub</span>
    </a>
    <nav class="flex items-center gap-1 sm:gap-4 text-sm">
      <a href={currentLang === 'en' ? '/' : `/${currentLang}/`} class:list={["px-3 py-2 rounded-md hover:text-[var(--color-primary)] transition-colors min-h-[44px] flex items-center", isToolPage && "text-[var(--color-primary)] font-medium"]}>{t?.nav.tool ?? 'Tool'}</a>
      <a href={currentLang === 'en' ? '/what-is-exif-data' : `/${currentLang}/what-is-exif-data`} class:list={["px-3 py-2 rounded-md hover:text-[var(--color-primary)] transition-colors min-h-[44px] flex items-center", isLearnPage && "text-[var(--color-primary)] font-medium"]}>{t?.nav.learn ?? 'Learn'}</a>

      {/* Language switcher */}
      <div class="relative" id="lang-switcher">
        <button
          class="px-3 py-2 rounded-md hover:text-[var(--color-primary)] transition-colors min-h-[44px] flex items-center gap-1 text-[var(--color-text-muted)]"
          aria-label={t?.nav?.switchLang || 'Switch language'}
          aria-expanded="false"
          aria-haspopup="true"
          id="lang-toggle"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
          <span class="hidden sm:inline">{langLabels[currentLang]}</span>
          <svg class="w-3 h-3 transition-transform duration-200" id="lang-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </button>
        <div class="absolute right-0 top-full mt-1 bg-white border border-[var(--color-border)] rounded-lg shadow-lg py-1 min-w-[140px] opacity-0 invisible transition-all z-50" id="lang-menu">
          {supportedLangs.map((l) => (
            <a
              href={formatLangPath(l, pathWithoutLang)}
              class:list={[
                "block px-4 py-2.5 text-sm no-underline hover:bg-blue-50 hover:text-[var(--color-primary)] transition-colors min-h-[44px]",
                l === currentLang && "text-[var(--color-primary)] font-medium bg-blue-50"
              ]}
            >
              {langLabels[l]}
            </a>
          ))}
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const switchers = document.querySelectorAll<HTMLElement>('#lang-switcher');
    switchers.forEach((switcher) => {
      const toggle = switcher.querySelector<HTMLButtonElement>('#lang-toggle');
      const menu = switcher.querySelector<HTMLElement>('#lang-menu');
      const chevron = switcher.querySelector<SVGElement>('#lang-chevron');
      if (!toggle || !menu) return;

      let open = false;
      let clickedOpen = false;

      function setOpen(value: boolean) {
        open = value;
        menu.classList.toggle('opacity-0', !open);
        menu.classList.toggle('invisible', !open);
        toggle.setAttribute('aria-expanded', String(open));
        if (chevron) chevron.style.transform = open ? 'rotate(180deg)' : '';
      }

      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        clickedOpen = !open;
        setOpen(!open);
      });

      document.addEventListener('click', (e) => {
        if (open && !switcher.contains(e.target as Node)) {
          clickedOpen = false;
          setOpen(false);
        }
      });

      // Hover only on desktop when not click-activated
      switcher.addEventListener('mouseenter', () => { if (!clickedOpen) setOpen(true); });
      switcher.addEventListener('mouseleave', () => { if (!clickedOpen) setOpen(false); });
    });
  });
</script>

---
interface Props {
  t?: {
    local: string; localDesc: string;
    noUpload: string; noUploadDesc: string;
    instant: string; instantDesc: string;
    free: string; freeDesc: string;
  };
}

const { t } = Astro.props;

const BADGES = [
  {
    icon: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    title: t?.local ?? '100% Local Processing',
    desc: t?.localDesc ?? 'Files never leave your browser',
  },
  {
    icon: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z',
    title: t?.noUpload ?? 'No Server Upload',
    desc: t?.noUploadDesc ?? 'Zero data leaves your device',
  },
  {
    icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
    title: t?.instant ?? 'Instant Results',
    desc: t?.instantDesc ?? 'No waiting, no signup needed',
  },
  {
    icon: 'M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z',
    title: t?.free ?? 'Free to Use',
    desc: t?.freeDesc ?? 'No signup, no limits',
  },
];
---

<div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">
  {BADGES.map((badge) => (
    <div class="flex flex-col items-center text-center p-4 sm:p-5 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] hover:border-blue-200 hover:shadow-sm transition-all">
      <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center mb-3 shrink-0">
        <svg class="w-5 h-5 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={1.5}>
          <path strokeLinecap="round" strokeLinejoin="round" d={badge.icon} />
        </svg>
      </div>
      <p class="text-sm font-semibold text-[var(--color-text)]">{badge.title}</p>
      <p class="text-xs text-[var(--color-text-muted)] mt-0.5">{badge.desc}</p>
    </div>
  ))}
</div>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExifRemover from '../components/ExifRemover';
import TrustBadges from '../components/TrustBadges.astro';
import FAQ from '../components/FAQ';
import { getTranslations } from '../i18n/utils';
import { getCollection } from 'astro:content';

const t = getTranslations('en');
const allDocs = (await getCollection('docs'))
  .filter((d) => d.data.lang === 'en')
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="EXIF Scrub — Free Photo Metadata Remover Online"
  description={t.site.description}
  faqSchema={t.faqItems}
  howToSchema={{
    name: 'How to Remove EXIF Metadata from Photos',
    steps: [
      { name: t.steps.step1Title, text: t.steps.step1Desc },
      { name: t.steps.step2Title, text: t.steps.step2Desc },
      { name: t.steps.step3Title, text: t.steps.step3Desc },
    ],
  }}
  lang="en"
>
  <div class="max-w-5xl mx-auto px-4 py-6 sm:py-8">
    {/* Privacy Alert */}
    <div class="mb-6 bg-red-50 border border-red-200 rounded-xl px-4 py-3 flex items-start gap-3">
      <svg class="w-5 h-5 text-red-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
      </svg>
      <div>
        <p class="text-sm font-semibold text-red-800">{t.alert.title}</p>
        <p class="text-sm text-red-700 mt-0.5">{t.alert.desc}</p>
      </div>
    </div>

    {/* Hero — only ONE h1 on the page */}
    <div class="text-center mb-6 sm:mb-8">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-3">{t.hero.title}</h1>
      <p class="text-[var(--color-text-muted)] text-base sm:text-lg">{t.hero.subtitle}</p>
    </div>

    {/* Tool */}
    <ExifRemover client:only="react" t={t} />

    {/* How It Works */}
    <div class="mt-12 sm:mt-16">
      <h2 class="text-xl sm:text-2xl font-bold text-center mb-8">{t.steps.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center p-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)]">
          <div class="w-12 h-12 rounded-full bg-blue-100 text-[var(--color-primary)] flex items-center justify-center mx-auto mb-4 text-xl font-bold">1</div>
          <h3 class="font-semibold mb-2">{t.steps.step1Title}</h3>
          <p class="text-sm text-[var(--color-text-muted)]">{t.steps.step1Desc}</p>
        </div>
        <div class="text-center p-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)]">
          <div class="w-12 h-12 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center mx-auto mb-4 text-xl font-bold">2</div>
          <h3 class="font-semibold mb-2">{t.steps.step2Title}</h3>
          <p class="text-sm text-[var(--color-text-muted)]">{t.steps.step2Desc}</p>
        </div>
        <div class="text-center p-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)]">
          <div class="w-12 h-12 rounded-full bg-green-100 text-green-600 flex items-center justify-center mx-auto mb-4 text-xl font-bold">3</div>
          <h3 class="font-semibold mb-2">{t.steps.step3Title}</h3>
          <p class="text-sm text-[var(--color-text-muted)]">{t.steps.step3Desc}</p>
        </div>
      </div>
    </div>

    {/* Trust badges */}
    <div class="mt-10 sm:mt-12">
      <TrustBadges t={t.badges} />
    </div>

    {/* SEO Content */}
    <div class="mt-12 sm:mt-16 max-w-3xl mx-auto">
      <h2 class="text-xl sm:text-2xl font-bold mb-4">{t.seoContent.title}</h2>
      <div class="space-y-4 text-[var(--color-text-muted)] text-sm leading-relaxed">
        <p>{t.seoContent.p1}</p>
        <p>{t.seoContent.p2}</p>
        <p>{t.seoContent.p3}</p>
      </div>
    </div>

    {/* FAQ section */}
    <div class="mt-12 sm:mt-16">
      <h2 class="text-xl sm:text-2xl font-bold text-center mb-6">{t.faq.title}</h2>
      <FAQ client:load items={t.faqItems} t={t} />
    </div>

    {/* CTA */}
    <div class="mt-12 sm:mt-16 text-center bg-gradient-to-br from-blue-50 to-indigo-50 border-2 border-blue-200 rounded-2xl p-5 shadow-sm">
      <h2 class="text-lg sm:text-xl font-bold mb-1">{t.cta.title}</h2>
      <p class="text-sm text-[var(--color-text-muted)] mb-3">{t.cta.desc}</p>
      <a href="#" id="cta-scroll-top" class="inline-flex items-center gap-2 px-7 py-2.5 bg-[var(--color-primary)] text-white rounded-xl font-semibold text-sm hover:bg-[var(--color-primary-dark)] transition-colors no-underline min-h-[44px] shadow-sm hover:shadow-md">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {t.cta.button}
      </a>
    </div>

    {/* Content link matrix */}
    <div class="mt-12 sm:mt-16">
      <h2 class="text-lg font-bold mb-4">{t.articles.learnMore}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        {allDocs.map((doc) => (
          <a
            href={`/${doc.data.slug}`}
            class="text-sm no-underline px-4 py-3 rounded-lg border border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors min-h-[44px] flex items-center"
          >
            {t.articleTitles[doc.data.slug] || doc.data.title}
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.getElementById('cta-scroll-top')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
